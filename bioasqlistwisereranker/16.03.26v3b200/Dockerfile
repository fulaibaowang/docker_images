# syntax=docker/dockerfile:1

# B200 / Blackwell-ready listwise reranking image.
# Keep the official vLLM base because it is the least fragile route for B200.
# You can override the base at build time, e.g.:
#   docker build --build-arg VLLM_BASE_IMAGE=vllm/vllm-openai:latest -f Dockerfile.listwise.b200 -t bioasq-listwise-b200 .
ARG VLLM_BASE_IMAGE=vllm/vllm-openai:latest
FROM ${VLLM_BASE_IMAGE}

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/root/.cache/huggingface \
    MPLBACKEND=Agg \
    TOKENIZERS_PARALLELISM=false \
    VLLM_ENABLE_V1_MULTIPROCESSING=0 \
    VLLM_WORKER_MULTIPROC_METHOD=spawn \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:${PATH}

WORKDIR /app

# Keep the vLLM / torch stack from the base image stable.
# Add only the extra packages used by your notebook / scripts.
RUN uv pip install --system \
    numpy \
    pandas \
    matplotlib \
    tqdm \
    jupyterlab \
    ipykernel \
    jupytext \
    faiss-cpu

# Install RankLLM without letting pip replace the curated vLLM stack.
RUN uv pip install --system --no-deps rank-llm==0.25.7 && \
    python3 -m pip install \
      dacite \
      ftfy \
      openai \
      tiktoken \
      pydantic \
      requests

# Patch RankLLM so importing Zephyr does not eagerly import the older
# generic Reranker / LiT5 path, which can conflict with newer Transformers stacks.
RUN python3 - <<'PY'
from pathlib import Path
import shutil
import site

for p in site.getsitepackages():
    init_py = Path(p) / 'rank_llm' / 'rerank' / '__init__.py'
    if init_py.exists():
        backup = init_py.with_suffix('.py.bak')
        shutil.copy2(init_py, backup)
        text = init_py.read_text(encoding='utf-8')
        text = text.replace('from .reranker import Reranker\n', '')
        init_py.write_text(text, encoding='utf-8')
        print(f'Patched {init_py} (backup: {backup})')
        break
else:
    raise SystemExit('Could not find rank_llm/rerank/__init__.py to patch')
PY

# Build-time smoke test: verify the exact import path you rely on.
RUN python3 - <<'PY'
import sys
print('Python:', sys.version)

import torch
print('torch:', torch.__version__)
print('torch CUDA build:', torch.version.cuda)

import vllm
print('vllm:', vllm.__version__)

import numpy as np
import pandas as pd
import matplotlib
import tqdm
print('numpy:', np.__version__)
print('pandas:', pd.__version__)
print('matplotlib:', matplotlib.__version__)
print('tqdm:', tqdm.__version__)

from rank_llm.data import Request, Candidate, Query
print('rank_llm.data: ok')

from rank_llm.rerank.listwise import ZephyrReranker
print('ZephyrReranker: ok')

print('All Zephyr-side imports OK')
PY

CMD ["bash", "-lc", "python3 - <<'PY'\nimport torch\nprint('torch', torch.__version__)\nprint('cuda available', torch.cuda.is_available())\nprint('cuda build', torch.version.cuda)\nprint('device count', torch.cuda.device_count())\nif torch.cuda.is_available():\n    print('device 0', torch.cuda.get_device_name(0))\n    print('capability', torch.cuda.get_device_capability(0))\nPY"]
